# Supabase (Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-anon-key

# Cloudflare Turnstile (Authentication → Bot and Abuse Protection in Supabase dashboard)
# Production: use your widget site key. Local dev: Turnstile test key always passes.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# FastAPI backend
VITE_FASTAPI_BASE_URL=http://localhost:8000

# Production example:
# VITE_FASTAPI_BASE_URL=https://frensify-backend-production.up.railway.app

# Password reset: add http://localhost:3000/auth/reset-password (and your production URL)
# under Supabase → Authentication → URL Configuration → Redirect URLs.
#
# Auth hardening (also in supabase/config.toml; push with `supabase config push`):
# - minimum_password_length = 10, lower_upper_letters_digits
# - enable_confirmations = true
# - Turnstile captcha: set SUPABASE_AUTH_CAPTCHA_SECRET before config push / in dashboard
