# Supabase (Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-anon-key

# FastAPI backend
VITE_FASTAPI_BASE_URL=http://localhost:8000

# Production example:
# VITE_FASTAPI_BASE_URL=https://frensify-backend-production.up.railway.app

# Password reset: add http://localhost:3000/auth/reset-password (and your production URL)
# under Supabase → Authentication → URL Configuration → Redirect URLs.
