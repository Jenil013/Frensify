# Same Supabase project as frontend VITE_SUPABASE_URL
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Project Settings → API → JWT Secret (legacy HS256). Must match the project that issues user tokens.
# Newer projects also sign with ES256; auth_jwt.py verifies those via JWKS using SUPABASE_URL.
SUPABASE_JWT_SECRET=your-jwt-secret

GEMINI_API_KEY_EVAL=
GEMINI_EVAL_MODEL=gemini-2.0-flash
GEMINI_API_KEY_UTILS=
GEMINI_UTILS_MODEL=gemini-2.0-flash

FRONTEND_URL=http://localhost:3000
