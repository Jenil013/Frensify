# Same Supabase project as frontend VITE_SUPABASE_URL
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Project Settings → API → JWT Secret (legacy HS256). Must match the project that issues user tokens.
# Newer projects also sign with ES256; auth_jwt.py verifies those via JWKS using SUPABASE_URL.
SUPABASE_JWT_SECRET=your-jwt-secret

GEMINI_API_KEY_EVAL=
GEMINI_EVAL_MODEL=gemini-3-flash-preview #Cost - Input: $0.5 / Output: $3 per million tokens
GEMINI_API_KEY_UTILS=
GEMINI_UTILS_MODEL=gemini-3.1-flash-lite  #Cost - Input: $0.25 / Output: $1.5 per million tokens

# Used for Stripe redirects and CORS (must match Cloudflare Pages URL in production).
FRONTEND_URL=http://localhost:3000

# Optional: comma-separated extra browser origins (e.g. PR preview URLs).
# CORS_ORIGINS=https://branch-name.your-project.pages.dev
